# Safe Station - Mandatory Environment Variables
# Fill these in for Meta OpenEnv Hackathon submission

# 1. API_BASE_URL: The endpoint for your LLM (e.g., OpenAI, Ollama, vLLM)
API_BASE_URL=http://localhost:11434/v1

# 2. MODEL_NAME: The model identifier to use
MODEL_NAME=safe-station-gpt

# 3. HF_TOKEN: Your Hugging Face API key (Used for model downloads/Spaces)
HF_TOKEN=your_token_here

# 4. LOCAL_IMAGE_NAME: The name of your local environment container image
LOCAL_IMAGE_NAME=safe_station:latest

# --- Optional ---
# ENV_URL: The address of your environment server (Local default is http://localhost:8000)
ENV_URL=http://localhost:8000
